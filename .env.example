# Copy this file to `.env` and fill in the values.
# `.env` is gitignored. NEVER commit real secret values.

# Best Buy Developer API key
#   Register at: https://developer.bestbuy.com/
BESTBUY_API_KEY=

# Dropbox app `AIGarpDataPipeline` (App-folder scope)
#   Portal: https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
